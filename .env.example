# Base URL of your app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Database (PostgreSQL — Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth
NEXTAUTH_SECRET=your-random-secret-min-32-chars
NEXTAUTH_URL=https://your-domain.vercel.app

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ETERNAL_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary (https://cloudinary.com/console)
# Create an unsigned upload preset named "legacyvault_uploads"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=LegacyVault <noreply@your-domain.com>

# Cron job security (generate a random string)
CRON_SECRET=your-random-cron-secret
